   441                           ;Config register CONFIG1H @ 0x300001
   442                           ;	Oscillator Selection bits
   443                           ;	OSC = IRCIO, Internal oscillator block, port function on RA6 and port function on RA7
   444                           ;	Fail-Safe Clock Monitor Enable bit
   445                           ;	FCMEN = 0x1, unprogrammed default
