   440                           ;Config register CONFIG1H @ 0x300001
   441                           ;	Oscillator Selection bits
   442                           ;	OSC = IRCIO, Internal oscillator block, port function on RA6 and port function on RA7
   443                           ;	Fail-Safe Clock Monitor Enable bit
   444                           ;	FCMEN = 0x1, unprogrammed default
